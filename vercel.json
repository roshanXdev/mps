{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter ignou-assignments run build",
  "outputDirectory": "artifacts/ignou-assignments/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/server.ts": {
      "runtime": "@vercel/node@3"
    }
  }
}